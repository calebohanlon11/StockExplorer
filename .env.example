# Copy this file to `.env` in the project root and fill in your values.
# `.env` is gitignored — do not commit secrets.

# Finnhub — https://finnhub.io/register
EXPO_PUBLIC_FINNHUB_API_KEY=

# Alpha Vantage — https://www.alphavantage.co/support/#api-key
EXPO_PUBLIC_ALPHA_VANTAGE_API_KEY=

# Optional: your sign-in email for free owner/admin access (legacy mode only, no Supabase)
EXPO_PUBLIC_ADMIN_EMAIL=

# Supabase — https://supabase.com/dashboard (Project Settings → API)
# Leave empty to use offline mock auth + local subscription state.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- EAS Build (cloud) ---
# Your gitignored `.env` is not uploaded. For `eas build`, define the same EXPO_PUBLIC_*
# variables for this project in the Expo dashboard (Project → Environment variables),
# scoped to "development" / "preview" / "production" as needed, or use:
#   npx eas-cli@latest env:create --help
# After `eas login` and `npm run eas:init`, Android dev build:
#   npm run eas:build:dev -- --platform android
# Install the APK, then: npm run start:dev
